// Nextflow config for the PGx tool benchmark.
// Run:  nextflow run benchmark/main.nf -profile docker
//
// One Docker image per caller (built from benchmark/docker/*.Dockerfile, tags pinned
// in conf/tool_versions.yml). The RUN_TOOL process resolves its container per-tool
// from params.images below.

params {
    samples_tsv = "${projectDir}/conf/samples.tsv"
    truth_tsv   = "${projectDir}/conf/truth.tsv"
    genes_yml   = "${projectDir}/conf/genes.yml"
    outdir      = "${projectDir}/results"
    workdata    = "${projectDir}/work/data"

    // Subsetting for smoke runs: comma lists or 'all'.
    samples = 'all'
    genes   = 'all'
    tools   = 'all'
    builds  = 'grch38,grch37'

    // tool -> docker image (Group A short-read/VCF + Group B long-read).
    images = [
        polygenic : 'pgxbench/polygenic:local',
        pharmcat  : 'pgxbench/pharmcat:2.15.5',
        pypgx     : 'pgxbench/pypgx:0.25.0',
        aldy      : 'pgxbench/aldy:4.6',
        stellarpgx: 'pgxbench/stellarpgx:1.2.7',
        cyrius    : 'pgxbench/cyrius:1.1.1',
        ursapgx   : 'pgxbench/ursapgx:1.0.0',
        pgxpop    : 'pgxbench/pgxpop:1.0',
        panno     : 'pgxbench/panno:0.2.0',
        t1k       : 'pgxbench/t1k:1.0.5',
        stargazer : 'pgxbench/stargazer:2.0.2',
        pbstarphase: 'pgxbench/pbstarphase:2.1.0',
        pangu     : 'pgxbench/pangu:0.2.8',
        decypher  : 'pgxbench/decypher:0.1.0',
        chinook   : 'pgxbench/wf-pgx:latest',
        specimmune: 'pgxbench/specimmune:1.0.0',
    ]
}

profiles {
    docker {
        docker.enabled = true
        // Mount the GRCh38 reference into every tool container and expose the env vars
        // the CRAM/long-read runners read (Aldy uses ALDY_REFERENCE; the rest PGXBENCH_GRCH38_REF).
        docker.runOptions = "-u \$(id -u):\$(id -g)" +
            " -e HOME=/tmp" +     // non-root user needs a writable HOME (pgstk writes ~/.pgstk)
            " -v ${projectDir}/work/ref:${projectDir}/work/ref:ro" +
            " -e PGXBENCH_GRCH38_REF=${projectDir}/work/ref/GRCh38_full_analysis_set_plus_decoy_hla.fa" +
            " -e ALDY_REFERENCE=${projectDir}/work/ref/GRCh38_full_analysis_set_plus_decoy_hla.fa"
    }
    // For local dev without containers (tools on PATH).
    local {
        docker.enabled = false
    }
}

process {
    errorStrategy = 'ignore'   // a single failed (tool,sample,gene) must not sink the run
    cpus = 2
    memory = '4 GB'
}

// NB: do NOT enable report/trace/timeline — they make Nextflow's task wrapper call
// `ps` for per-task metrics, which the slim tool images lack, failing every task.
